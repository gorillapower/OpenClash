#!/bin/sh

set -eu

host="${ROUTER_SSH_HOST:-router-temp}"
script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
remote_script="${script_dir}/router/lifecycle-smoke.remote.sh"
repo_root=$(CDPATH= cd -- "${script_dir}/.." && pwd)
init_script="${repo_root}/luci-app-clashnivo/root/etc/init.d/clashnivo"
lifecycle_script="${repo_root}/luci-app-clashnivo/root/usr/share/clashnivo/service/lifecycle.sh"
guard_script="${repo_root}/luci-app-clashnivo/root/usr/share/clashnivo/service/guard.sh"

scp -O "$remote_script" "${host}:/tmp/lifecycle-smoke.remote.sh"
scp -O "$init_script" "${host}:/tmp/clashnivo.init.test"
scp -O "$lifecycle_script" "${host}:/tmp/clashnivo.lifecycle.test"
scp -O "$guard_script" "${host}:/tmp/clashnivo.guard.test"
exec ssh -o BatchMode=yes "$host" sh /tmp/lifecycle-smoke.remote.sh
