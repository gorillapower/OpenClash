VITE_ROUTER_URL=http://192.168.1.1

# Clash REST API — two separate vars:
#   CLASH_TARGET = server-side proxy target (not in browser bundle)
#   VITE_CLASH_URL = what the browser calls (use /clash-api to go through Vite proxy)
CLASH_TARGET=http://192.168.1.1:9090
VITE_CLASH_URL=/clash-api

# Dev only: paste your sysauth cookie from browser devtools (logged into LuCI)
# Chrome: DevTools → Application → Cookies → copy the name=value pair
# Common names: sysauth / sysauth_http / sysauth_https (varies by router/firmware)
# VITE_ROUTER_COOKIE=sysauth=PASTE_VALUE_HERE

# Dev only: Clash API secret (set in your clash config as 'secret:')
# VITE_CLASH_SECRET=your_secret_here
