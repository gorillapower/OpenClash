VITE_ROUTER_URL=http://192.168.1.1
# Clash REST API target — Vite proxies /clash-api → this URL to avoid CORS
VITE_CLASH_URL=http://192.168.1.1:9090

# Dev only: paste your sysauth cookie from browser devtools (logged into LuCI)
# Chrome: DevTools → Application → Cookies → pick sysauth_http or sysauth_https
# VITE_ROUTER_COOKIE=sysauth_http=PASTE_VALUE_HERE

# Dev only: Clash API secret (set in your clash config as 'secret:')
# VITE_CLASH_SECRET=your_secret_here
